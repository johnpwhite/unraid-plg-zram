                    The defaults (100 / 10) are designed for that ordering and are what almost every install should use.
                </div>
                <dl>
                    <dt>Tier 1 (ZRAM) priority:</dt>
                    <dd><input type="number" id="zram_priority_input" min="1" max="32767" value="<?php echo intval($settings['zram_priority'] ?? 100); ?>" disabled></dd>
                    <dt>Tier 2 (Disk) priority:</dt>
                    <dd><input type="number" id="ssd_priority_input" min="0" max="32767" value="<?php echo intval($settings['ssd_swap_priority'] ?? 10); ?>" disabled></dd>
                    <dt></dt>
                    <dd>
                        <button type="button" class="zram-btn" id="btn-save-priorities" onclick="savePriorities()" disabled>SAVE</button>
                        <button type="button" class="zram-btn" onclick="resetPriorities()">RESET TO DEFAULTS</button>
                    </dd>
                </dl>
            </div>
        </details>
    </div>
</div>
</div>

<!-- ACTIVITY PANE — unified feed of cmd.log + debug.log with filter chips.
     Replaces the old two-tab "Command History / System Debug Log" UI.
     See docs/specs/UNIFIED_ACTIVITY_LOG.md. -->
<div class="zram-console-pane" id="zram-console-pane">
    <div class="zram-activity-header">
        <div class="zram-activity-title"><i class="fa fa-list-alt"></i> Activity</div>
        <div class="zram-activity-chips">
            <button type="button" class="activity-chip active" data-filter="all">All</button>
            <button type="button" class="activity-chip" data-filter="commands">Commands</button>
            <button type="button" class="activity-chip" data-filter="events">Events</button>
            <button type="button" class="activity-chip" data-filter="errors">Errors</button>
        </div>
    </div>
    <div id="activity-log"></div>
    <div class="zram-activity-footer">
        <button type="button" class="zram-btn" onclick="fetchActivity()"><i class="fa fa-refresh"></i> REFRESH</button>
        <button type="button" class="zram-btn zram-btn-danger" onclick="clearActivity()"><i class="fa fa-trash"></i> CLEAR</button>
    </div>
</div>
</div>
