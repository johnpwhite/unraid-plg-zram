parameters:
    level: 5
    paths:
        - src
    excludePaths:
        # `(?)` marks the path optional — these directories don't exist in
        # this plugin layout (tests live at top-level tests/, no vendor in
        # src/). Leaving them as hard requirements aborts phpstan with
        # "Invalid entries in excludePaths" before analysis runs.
        - src/tests (?)
        - src/vendor (?)
        - src/*.page
    ignoreErrors:
        # .page files declare $docroot / $var / $mytiles via Unraid's templating layer
        - '#Undefined variable: \$docroot#'
        - '#Undefined variable: \$var#'
        - '#Undefined variable: \$mytiles#'
        # Unraid's auto-loaded globals
        - '#Constant ZRAM_[A-Z_]+ not found#'
